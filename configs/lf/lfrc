# Basic Settings
set shell sh
set shellopts '-eu'
set scrolloff 10
set drawbox true
set ignorecase true

# Crear carpetas
cmd mkdir &{{
    mkdir -pv "$1"
}}

# Crear archivos
cmd mkfile &{{
    touch "$1"
}}

# Papelera
cmd trash &{{
  mkdir -p ~/.local/share/Trash/files

  printf '%s\n' "$fx" | while IFS= read -r file; do
    [ -z "$file" ] && continue

    base=$(basename "$file")
    dest="$HOME/.local/share/Trash/files/$base"

    # si existe, agregar sufijo aleatorio
    if [ -e "$dest" ]; then
        rand=$(tr -dc a-z0-9 </dev/urandom | head -c 6)
        dest="$HOME/.local/share/Trash/files/${base}_$rand"
    fi

    mv -- "$file" "$dest"
  done
}}

# Limpiar papelera
cmd trashClear &{{
    rm -rf ~/.local/share/Trash/files/*
}}

# Abrir archivos
cmd open &{{
	case $(file --mime-type -Lb $f) in
		text/*) lf -remote "send $id \$nvim \$fx";;
        image/*) lf -remote "send $id \$feh --auto-zoom \$fx &";;
        audio/*) lf -remote "send $id \$mpv --audio-display=no \$fx";;
        video/*) setsid -f mpv "$f" -quiet >/dev/null 2>&1 ;;
        application/pdf*) setsid -f mupdf "$fx" >/dev/null 2>&1 ;;
		*) xdg-open "$f"

        #/*) lf -remote "send $id \$ \$fx";; # abrir dentro de lf
        #/*) setsid -f command "$fx" -quiet >/dev/null 2>&1 ;; # abrir fuera de lf
	esac
}}

# Comprimir archivos
cmd compress ${{
    name="$1"
    fmt="$2"

    case "$fmt" in
        zip)
            zip -r "$name.zip" $fx
            ;;
        7z)
            7z a "$name.7z" $fx
            ;;
        tar)
            tar czf "$name.tar.gz" $fx
            ;;
    esac
}}

# Descomprimir archivos
cmd extract ${{
    set -f
    case "$f" in
        *.tar.bz|*.tar.bz2|*.tbz|*.tbz2) tar xjvf "$f";;
        *.tar.gz|*.tgz) tar xzvf "$f";;
        *.tar.xz|*.txz) tar xJvf "$f";;
        *.zip) unzip "$f";;
        *.rar) unrar x "$f";;
        *.7z) 7z x "$f";;
        *) echo "Unsupported format" ;;
    esac
}}

# Cambiar fondo de pantalla
cmd setWallpaper ${{
    feh --bg-fill "$f"
}}

# Bindings
map c
map d
map m

# Basic Functions
map . set hidden!

map ac push :compress<space>
map ae extract 

map dd trash
map dc trashClear

map x cut
map y copy
map p paste
map u :unselect; clear

map <enter> open
map R reload
map mf push :mkfile<space>
map md push :mkdir<space>
map C clear

map bg setWallpaper

# Movement
map gc cd ~/.config
map gC cd ~/Codigo
map gD cd ~/Documentos
map gd cd ~/Descargas
map gp cd ~/Imàgenes
map gv cd ~/Vídeos
map gr cd ~/repos
map gs cd ~/.local/bin
map gt cd ~/.local/share/Trash/files

